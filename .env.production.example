# Copy this file to .env on your production server and replace all placeholders.

PANEL_DOMAIN=panel.example.com
HY2_DOMAIN=hy2.example.com
PUBLIC_BASE_URL=https://panel.example.com

DEFAULT_VLESS_ADDRESS=vless.example.com
DEFAULT_VLESS_NAME=VLESS_Reality_vless.example.com
DEFAULT_HY2_NAME=HY2_hy2.example.com
HY2_MASQUERADE_URL=https://example.com

PANEL_HOST=127.0.0.1
PANEL_PORT=9100
PANEL_DIR=/opt/xray-proxy-panel

XRAY_BIN=xray
XRAY_API_SERVER=127.0.0.1:10085
XRAY_CONFIG=/usr/local/etc/xray/config.json
XRAY_BACKUP_DIR=/root/xray-config-backups
XRAY_RESTART_CMD=systemctl restart xray
XRAY_STATUS_CMD=systemctl is-active xray

HY2_DIR=/opt/hysteria2
HY2_CONFIG_FILE=/opt/hysteria2/server.yaml
HY2_BACKUP_DIR=/root/hysteria2-config-backups
HY2_RESTART_CMD=docker compose -f /opt/hysteria2/docker-compose.yml restart hysteria2
HY2_STATUS_CMD=docker inspect -f "{{.State.Running}}" hysteria2
HY2_LOGS_CMD=docker logs --tail=80 hysteria2

QR_CMD=qrencode
